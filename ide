            text = f.read_text()
            if f"use crate::{target_name}" in text or f"mod {target_name}" in text or f"{target_name}::" in text:
                rel = f.relative_to(IDE_ROOT)
                src_hits.append(str(rel))

    if hits:
        print(f"IMPACT: {target_name} is used by {len(hits)} test/bin files:")
        for path, count in hits:
            print(f"  {path} ({count} refs)")
    else:
