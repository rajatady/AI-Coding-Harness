#!/usr/bin/env python3
"""
AI-Native IDE — Correctness Construction System.

NOT a project tracker. NOT a test runner.
A system that helps AI write code that CANNOT be wrong.

Core principle: every verification should cost near-zero context.
Types verify for free. Compilation is a binary signal.
Rich error output is a human luxury I can't afford.
"""
import json
import os
import re
import subprocess
import sys
from datetime import datetime
from pathlib import Path
from textwrap import dedent

IDE_ROOT = Path(__file__).parent.resolve()
DECISIONS_DIR = IDE_ROOT / ".decisions"
TASKS_DIR = IDE_ROOT / ".tasks"
MODULES_DIR = IDE_ROOT / ".modules"
CONTRACTS_DIR = IDE_ROOT / ".contracts"
JOURNALS_DIR = IDE_ROOT / ".journals"

for d in [DECISIONS_DIR, TASKS_DIR, MODULES_DIR, CONTRACTS_DIR, JOURNALS_DIR]:
    d.mkdir(exist_ok=True)


def load_json(path: Path) -> dict:
    with open(path) as f:
        return json.load(f)


def save_json(path: Path, data: dict):
    with open(path, "w") as f:
        json.dump(data, f, indent=2)


# ─── orient ──────────────────────────────────────────────────────────────
def cmd_orient(args):
    """
    Focused orientation. Costs ~200 tokens instead of 1000+.
    Usage:
        ./ide orient          — minimal: active task + next task only
        ./ide orient full     — everything (expensive, avoid)
        ./ide orient <module> — just that module's state
    """
    mode = args[0] if args else "minimal"

    if mode == "minimal":
        # Active task only
        active = None
        next_ready = None
        for f in sorted(TASKS_DIR.glob("*.json")):
            t = load_json(f)
            if t["status"] == "active" and not active:
                active = t
            if t["status"] == "pending" and not t.get("blocked_by") and not next_ready:
                next_ready = t

        if active:
            print(f"ACTIVE: [{active['id']}] {active['title']}")
            if active.get("module"):
                print(f"  module: {active['module']}")
            for i, s in enumerate(active.get("subtasks", [])):
                mark = "x" if s.get("done") else " "
                print(f"  [{mark}] {i}: {s['title']}")
            # Show journal if one exists for this task
            journal_path = JOURNALS_DIR / f"{active['id']}.md"
            if journal_path.exists():
                content = journal_path.read_text().strip()
                # Show only — compact, not the whole file
                lines = content.split("\n")
                for line in lines[:15]:  # Max 15 lines
                    print(f"  | {line}")
                if len(lines) > 15:
                    print(f"  | ... ({len(lines) - 15} more lines)")
        else:
            print("ACTIVE: (none)")

        if next_ready:
            print(f"NEXT: [{next_ready['id']}] {next_ready['title']}")

        # Compile status if cargo project exists
        cargo_toml = IDE_ROOT / "Cargo.toml"
        if cargo_toml.exists():
            result = subprocess.run(
                ["cargo", "check", "--message-format=short"],
                capture_output=True, text=True, cwd=IDE_ROOT, timeout=120
            )
            if result.returncode == 0:
                print("BUILD: OK")
            else:
                # Extract just the first error
                lines = result.stderr.strip().split("\n")
                first_error = None
                for line in lines:
                    if "error[" in line or "error:" in line:
                        first_error = line.strip()
                        break
                print(f"BUILD: FAIL — {first_error or 'unknown error'}")

    elif mode == "full":
        # Everything — expensive, use sparingly
        print("=== FULL ORIENTATION ===")
        for f in sorted(TASKS_DIR.glob("*.json")):
            t = load_json(f)
            status_mark = {"active": ">>", "pending": "  ", "done": "OK", "blocked": "BL"}.get(t["status"], "??")
            blocked = f" (blocked: {','.join(t['blocked_by'])})" if t.get("blocked_by") else ""
            print(f"  {status_mark} [{t['id']}] {t['title']}{blocked}")
        print()
        for f in sorted(MODULES_DIR.glob("*.json")):
            m = load_json(f)
            print(f"  [{m['status']}] {m['name']}: {m['purpose']}")
        print()
        dec_files = sorted(DECISIONS_DIR.glob("*.json"), key=os.path.getmtime, reverse=True)[:5]
        for f in dec_files:
            d = load_json(f)
            print(f"  {d['id']}: {d['choice']} — {d['why'][:80]}")

    else:
        # Module-specific orientation
        mod_path = MODULES_DIR / f"{mode}.json"
        if not mod_path.exists():
            print(f"Module '{mode}' not found")
            sys.exit(1)
        m = load_json(mod_path)
        print(f"MODULE: {m['name']} [{m['status']}]")
        print(f"PURPOSE: {m['purpose']}")
        if m.get("files"):
            print(f"FILES: {', '.join(m['files'])}")
        if m.get("public_api"):
            print("API:")
            for api in m["public_api"]:
                print(f"  {api['name']}: {api['signature']}")
        if m.get("dependencies"):
            print(f"DEPS: {', '.join(m['dependencies'])}")
        if m.get("known_issues"):
            print(f"ISSUES: {len(m['known_issues'])}")
            for issue in m["known_issues"]:
                print(f"  - {issue}")
        # Show related contract
        contract_path = CONTRACTS_DIR / f"{mode}.rs"
        if contract_path.exists():
            print(f"CONTRACT: {contract_path}")


# ─── check ───────────────────────────────────────────────────────────────
def cmd_check(args):
    """
    Binary compilation check. THE most important tool.
    Returns: OK or FAIL + first error only.
    Cost: ~20-50 tokens. Compare to running tests: ~500-5000 tokens.

    Usage:
        ./ide check           — cargo check (type verification)
        ./ide check build     — cargo build (full compilation)
        ./ide check wasm      — cargo build --target wasm32-unknown-unknown
        ./ide check test      — cargo test, but ONLY pass/fail count
        ./ide check render    — deterministic pixel verification
        ./ide check spec      — apple_website.rs executable spec (release)
        ./ide check perf      — 80K objects benchmark only
        ./ide check clippy    — cargo clippy, only error count + first error
        ./ide check ts        — TypeScript type check
    """
    mode = args[0] if args else "check"
    cargo_toml = IDE_ROOT / "Cargo.toml"
    if not cargo_toml.exists():
        print("NO_CARGO")
        return

    if mode == "all":
        # Check everything: Rust + WASM + TypeScript + Tests + FPS + Workflow
        for m in ["check", "wasm", "ts", "test", "fps", "workflow"]:
            cmd_check([m])
        return

    if mode == "check":
        result = subprocess.run(
            ["cargo", "check", "--message-format=short"],
            capture_output=True, text=True, cwd=IDE_ROOT, timeout=120
        )
        if result.returncode == 0:
            print("CHECK: OK")
        else:
            _print_first_error(result.stderr)

    elif mode == "build":
        result = subprocess.run(
            ["cargo", "build", "--message-format=short"],
            capture_output=True, text=True, cwd=IDE_ROOT, timeout=180
        )
        if result.returncode == 0:
            print("BUILD: OK")
        else:
            _print_first_error(result.stderr)

    elif mode == "wasm":
        # Full pipeline: cargo build + wasm-bindgen
        result = subprocess.run(
            ["cargo", "build", "-p", "figma-wasm", "--target", "wasm32-unknown-unknown",
             "--release", "--message-format=short"],
            capture_output=True, text=True, cwd=IDE_ROOT, timeout=180
        )
        if result.returncode != 0:
            _print_first_error(result.stderr)
            return

        wasm_file = IDE_ROOT / "target" / "wasm32-unknown-unknown" / "release" / "figma_wasm.wasm"
        out_dir = IDE_ROOT / "app" / "pkg"
        out_dir.mkdir(parents=True, exist_ok=True)
        result2 = subprocess.run(
            ["wasm-bindgen", str(wasm_file), "--out-dir", str(out_dir), "--target", "web"],
            capture_output=True, text=True, timeout=30
        )
        if result2.returncode != 0:
            print(f"WASM: BUILD OK, BINDGEN FAIL — {result2.stderr.strip()[:150]}")
        else:
            print("WASM: OK (built + bound)")

    elif mode == "test":
        result = subprocess.run(
            ["cargo", "test", "--", "--format=terse"],
            capture_output=True, text=True, cwd=IDE_ROOT, timeout=300
        )
        combined = result.stdout + result.stderr
        # Sum ALL "test result:" lines across crates
        matches = re.findall(r"test result: (\w+)\. (\d+) passed; (\d+) failed", combined)
        if matches:
            total_passed = sum(int(m[1]) for m in matches)
            total_failed = sum(int(m[2]) for m in matches)
            status = "FAIL" if total_failed > 0 else "OK"
            print(f"TEST: {status} — {total_passed} passed, {total_failed} failed")
            if total_failed > 0:
                for line in combined.split("\n"):
                    if "FAILED" in line or "panicked" in line:
                        print(f"  FIRST FAIL: {line.strip()[:120]}")
                        break
        elif result.returncode == 0:
            print("TEST: OK (no tests found)")
        else:
            print("TEST: FAIL (compilation error)")
            _print_first_error(result.stderr)

    elif mode == "render":
        # Run render verification binary + snapshot diff in one command
        result = subprocess.run(
            ["cargo", "run", "--bin", "render_verify"],
            capture_output=True, text=True, cwd=IDE_ROOT, timeout=120
        )
        for line in result.stdout.strip().split("\n"):
            if line.startswith("RENDER:"):
                print(line)
        if result.returncode != 0:
            for line in result.stderr.strip().split("\n"):
                if "FAIL" in line:
                    print(line.strip()[:150])
                    break
        # Also run snapshot diff if baseline exists
        baseline = SNAPSHOTS_DIR / "baseline.json"
        if baseline.exists():
            current = _run_snapshot_export()
            if current:
                bl = load_json(baseline)
                bl_tests = bl.get("tests", {})
                cu_tests = current.get("tests", {})
                changed = [n for n in cu_tests if n in bl_tests and bl_tests[n]["hash"] != cu_tests[n]["hash"]]
                if changed:
                    print(f"SNAPSHOT: {len(changed)} changed: {', '.join(changed)}")
                else:
                    print(f"SNAPSHOT: OK")

    elif mode == "ts":
        app_dir = IDE_ROOT / "app"
        if not app_dir.exists():
            print("TS: NO_APP_DIR")
            return
        result = subprocess.run(
            ["npx", "tsc", "--noEmit", "--pretty", "false"],
            capture_output=True, text=True, cwd=app_dir, timeout=60
        )
        if result.returncode == 0:
            print("TS: OK")
        else:
            lines = result.stdout.strip().split("\n")
            errors = [l for l in lines if ": error " in l]
            print(f"TS: {len(errors)} errors")
            if errors:
                print(f"  FIRST: {errors[0].strip()[:150]}")

    elif mode == "clippy":
        result = subprocess.run(
            ["cargo", "clippy", "--message-format=short", "--", "-D", "warnings"],
            capture_output=True, text=True, cwd=IDE_ROOT, timeout=120
        )
        if result.returncode == 0:
            print("CLIPPY: OK")
        else:
            errors = [l for l in result.stderr.split("\n") if "error" in l.lower() or "warning" in l.lower()]
            print(f"CLIPPY: {len(errors)} issues")
            if errors:
                print(f"  FIRST: {errors[0].strip()[:120]}")

    elif mode == "spec":
        # Run the executable specification (apple_website.rs) in release mode
        result = subprocess.run(
            ["cargo", "test", "-p", "figma-renderer", "--test", "apple_website",
             "--release", "--", "--nocapture"],
            capture_output=True, text=True, cwd=IDE_ROOT, timeout=300
        )
        combined = result.stdout + result.stderr
        # Extract test results
        matches = re.findall(r"test result: (\w+)\. (\d+) passed; (\d+) failed", combined)
        if matches:
            total_passed = sum(int(m[1]) for m in matches)
            total_failed = sum(int(m[2]) for m in matches)
            # Extract perf numbers if present
            perf = ""
            for line in combined.split("\n"):
                if "TOTAL:" in line:
                    perf = f" | {line.strip()}"
                    break
            status = "FAIL" if total_failed > 0 else "OK"
            print(f"SPEC: {status} — {total_passed} passed, {total_failed} failed{perf}")
            if total_failed > 0:
                for line in combined.split("\n"):
                    if "FAILED" in line or "panicked" in line or "RENDER TOO SLOW" in line:
                        print(f"  {line.strip()[:150]}")
                        break
        elif result.returncode == 0:
            print("SPEC: OK (no tests found)")
        else:
            print("SPEC: FAIL (compilation error)")
            _print_first_error(result.stderr)

    elif mode == "perf":
        # Run just the 80K performance benchmark
        result = subprocess.run(
            ["cargo", "test", "-p", "figma-renderer", "--test", "apple_website",
             "p8_80k", "--release", "--", "--nocapture"],
            capture_output=True, text=True, cwd=IDE_ROOT, timeout=300
        )
        combined = result.stdout + result.stderr
        for line in combined.split("\n"):
            if "TOTAL:" in line or "80K objects" in line:
                print(line.strip())
        if result.returncode != 0:
            print("PERF: FAIL")
            for line in combined.split("\n"):
                if "RENDER TOO SLOW" in line or "panicked" in line:
                    print(f"  {line.strip()[:150]}")
                    break
        else:
            print("PERF: OK")

    elif mode == "visual":
        # Build WASM first, then run visual check
        cmd_check(["wasm"])
        cmd_visual(args)

    elif mode == "fps":
        # Build WASM first, then measure fps
        cmd_check(["wasm"])
        cmd_fps(args)

    elif mode == "workflow":
        # Build WASM first, then run workflow tests
        cmd_check(["wasm"])
        cmd_workflow(args)

    else:
        print(f"Unknown check mode: {mode}")
        print("Modes: check, build, wasm, test, render, spec, perf, ts, clippy, visual, fps, workflow, all")


def _print_first_error(stderr: str):
    """Extract and print only the first error. Minimal context cost."""
    lines = stderr.strip().split("\n")
    for line in lines:
        if "error[" in line or (line.startswith("error") and ":" in line):
            print(f"FAIL: {line.strip()[:150]}")
            return
    # Fallback: first non-empty line
    for line in lines:
        if line.strip():
            print(f"FAIL: {line.strip()[:150]}")
            return
    print("FAIL: unknown")


# ─── contract ────────────────────────────────────────────────────────────
def cmd_contract(args):
    """
    Generate and manage type contracts.
    A contract is a Rust trait + types that ENFORCE module boundaries.
    If it compiles, the contract is satisfied. Zero-cost verification.

    Usage:
        ./ide contract create <module> <description>
            — generates .contracts/<module>.rs with trait skeleton
        ./ide contract show <module>
            — display the contract
        ./ide contract check <module>
            — verify the contract compiles (binary signal)
        ./ide contract list
            — list all contracts with compile status
    """
    if not args:
        print("Usage: ./ide contract <create|show|check|list> ...")
        sys.exit(1)
    sub = args[0]

    if sub == "create":
        name = args[1]
        desc = args[2] if len(args) > 2 else ""
        contract_path = CONTRACTS_DIR / f"{name}.rs"
        # Generate skeleton with the description as doc comment
        content = dedent(f"""\
            //! Contract for module: {name}
            //! {desc}
            //!
            //! This file defines the TYPE-LEVEL CONTRACT for this module.
            //! If this compiles, the contract is enforced.
            //! Implementors must satisfy these trait bounds.

            // TODO: Define the trait that enforces this module's guarantees.
            // The types should make incorrect implementations UNCOMPILABLE.
            //
            // Example patterns:
            //   - Typestate pattern: encode valid states in the type system
            //   - Phantom types: tag data with compile-time properties
            //   - Sealed traits: prevent external implementation
            //   - Const generics: encode numeric constraints in types
        """)
        contract_path.write_text(content)
        print(f"Contract created: {contract_path}")

    elif sub == "show":
        name = args[1]
        contract_path = CONTRACTS_DIR / f"{name}.rs"
        if contract_path.exists():
            print(contract_path.read_text())
        else:
            print(f"No contract for '{name}'")

    elif sub == "check":
        name = args[1]
        contract_path = CONTRACTS_DIR / f"{name}.rs"
        if not contract_path.exists():
            print(f"No contract for '{name}'")
            return
        # Try to compile just this file
        result = subprocess.run(
            ["rustc", "--edition=2021", "--crate-type=lib", str(contract_path), "-o", "/dev/null"],
            capture_output=True, text=True, timeout=30
        )
        if result.returncode == 0:
            print(f"CONTRACT {name}: OK")
        else:
            _print_first_error(result.stderr)

    elif sub == "list":
        for f in sorted(CONTRACTS_DIR.glob("*.rs")):
            name = f.stem
            result = subprocess.run(
                ["rustc", "--edition=2021", "--crate-type=lib", str(f), "-o", "/dev/null"],
                capture_output=True, text=True, timeout=30
            )
            status = "OK" if result.returncode == 0 else "FAIL"
            print(f"  [{status}] {name}")

    else:
        print(f"Unknown contract subcommand: {sub}")


# ─── scaffold ────────────────────────────────────────────────────────────
def cmd_scaffold(args):
    """
    Generate Rust module skeleton from a contract.
    The skeleton includes all required type definitions and trait impls
    with todo!() bodies. If the skeleton compiles, the structure is correct.
    I only need to fill in logic.

    Usage:
        ./ide scaffold <module-name> <output-dir>
    """
    if len(args) < 2:
        print("Usage: ./ide scaffold <module-name> <output-dir>")
        sys.exit(1)
    name = args[0]
    output_dir = Path(args[1])
    output_dir.mkdir(parents=True, exist_ok=True)

    contract_path = CONTRACTS_DIR / f"{name}.rs"
    if not contract_path.exists():
        print(f"No contract for '{name}'. Create one first: ./ide contract create {name}")
        sys.exit(1)

    # Read contract, extract trait definitions
    contract_text = contract_path.read_text()

    # Generate mod.rs that includes the contract and stubs
    mod_path = output_dir / "mod.rs"
    content = dedent(f"""\
        //! Module: {name}
        //! Generated from contract. Fill in the todo!() implementations.

        // Include the contract (type-level guarantees)
        // mod contract; // Uncomment when contract is integrated into crate

        // TODO: Implement the traits defined in the contract.
        // The type signatures are your guide. If it compiles, it's structurally correct.
        // Focus ONLY on filling in logic — the types prevent structural errors.
    """)
    mod_path.write_text(content)
    print(f"Scaffold created: {output_dir}/mod.rs")
    print(f"Next: implement traits from {contract_path}")


