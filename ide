def cmd_snapshot(args):
    """
    Render snapshot management — baseline + diff for pixel-level regression detection.

    Usage:
        ./ide snapshot           — run all render tests, show status vs baseline
        ./ide snapshot save      — capture current render hashes as baseline
        ./ide snapshot diff      — compare current vs baseline, show which changed
        ./ide snapshot dump      — export raw RGBA files to .snapshots/ for deep inspection
        ./ide snapshot pixeldiff <test> — byte-level diff of one test vs baseline
    """
    sub = args[0] if args else "status"
    baseline_path = SNAPSHOTS_DIR / "baseline.json"

    if sub == "save":
        # Capture current state as baseline
        current = _run_snapshot_export()
        if current is None:
            return
        save_json(baseline_path, current)
        print(f"SNAPSHOT: baseline saved ({len(current['tests'])} tests)")
        for name, info in current["tests"].items():
            print(f"  {name}: hash={info['hash']} pixels={info['coverage']}")

    elif sub == "diff":
        if not baseline_path.exists():
            print("SNAPSHOT: no baseline. Run './ide snapshot save' first.")
            return
        baseline = load_json(baseline_path)
        current = _run_snapshot_export()
        if current is None:
            return
        _show_diff(baseline, current)

    elif sub == "dump":
        # Export raw pixel data
        result = subprocess.run(
            ["cargo", "run", "--bin", "snapshot_export", "--", "--dump"],
            capture_output=True, text=True, cwd=IDE_ROOT, timeout=120
        )
        if result.returncode != 0:
            print(f"SNAPSHOT: FAIL — {result.stderr.strip()[:150]}")
            return
        raw_files = list(SNAPSHOTS_DIR.glob("*.raw"))
        print(f"SNAPSHOT: dumped {len(raw_files)} raw files to .snapshots/")
        for f in sorted(raw_files):
            size = f.stat().st_size
            print(f"  {f.name}: {size} bytes ({int(size/4)} pixels)")

    elif sub == "pixeldiff":
        if len(args) < 2:
            print("Usage: ./ide snapshot pixeldiff <test-name>")
            return
        test_name = args[1]
        _pixel_diff(test_name, baseline_path)

    else:  # status
        current = _run_snapshot_export()
        if current is None:
            return
        if baseline_path.exists():
            baseline = load_json(baseline_path)
            _show_diff(baseline, current)
        else:
            print(f"SNAPSHOT: {len(current['tests'])} tests (no baseline)")
            for name, info in current["tests"].items():
                print(f"  {name}: hash={info['hash']} pixels={info['coverage']}")


def _run_snapshot_export() -> dict | None:
    """Run snapshot_export binary and parse output."""
    result = subprocess.run(
        ["cargo", "run", "--bin", "snapshot_export"],
        capture_output=True, text=True, cwd=IDE_ROOT, timeout=120
    )
    if result.returncode != 0:
        # Check if it's just a build issue
        _print_first_error(result.stderr)
        return None

    tests = {}
    summary = None
    for line in result.stdout.strip().split("\n"):
        if line.startswith("TEST:"):
            parts = line.split(":")
            # TEST:name:width:height:hash:coverage
            if len(parts) >= 6:
                tests[parts[1]] = {
                    "width": int(parts[2]),
                    "height": int(parts[3]),
                    "hash": parts[4],
                    "coverage": parts[5],
                }
        elif line.startswith("SUMMARY:"):
            summary = line[8:]

    return {"tests": tests, "summary": summary}


def _show_diff(baseline: dict, current: dict):
    """Compare baseline and current snapshots."""
    bl_tests = baseline.get("tests", {})
    cu_tests = current.get("tests", {})

    changed = []
    added = []
    removed = []
    same = []

    for name in sorted(set(list(bl_tests.keys()) + list(cu_tests.keys()))):
        if name in bl_tests and name in cu_tests:
            if bl_tests[name]["hash"] == cu_tests[name]["hash"]:
                same.append(name)
            else:
                changed.append(name)
        elif name in cu_tests:
            added.append(name)
        else:
            removed.append(name)

    total = len(same) + len(changed) + len(added) + len(removed)
    if not changed and not added and not removed:
        print(f"SNAPSHOT: OK — {len(same)} tests unchanged")
    else:
        print(f"SNAPSHOT: {len(changed)} changed, {len(added)} added, {len(removed)} removed, {len(same)} same")
        for name in changed:
            old_cov = bl_tests[name]["coverage"]
            new_cov = cu_tests[name]["coverage"]
            cov_note = f" (coverage: {old_cov} → {new_cov})" if old_cov != new_cov else ""
            print(f"  CHANGED: {name}{cov_note}")
        for name in added:
            print(f"  NEW: {name}")
        for name in removed:
            print(f"  GONE: {name}")


def _pixel_diff(test_name: str, baseline_path: Path):
    """Deep pixel diff of one test: dump both baseline and current, compare byte-by-byte."""
    if not baseline_path.exists():
        print("No baseline. Run './ide snapshot save' first.")
        return

    # Dump current
    result = subprocess.run(
        ["cargo", "run", "--bin", "snapshot_export", "--", "--dump"],
        capture_output=True, text=True, cwd=IDE_ROOT, timeout=120
    )
    if result.returncode != 0:
        print(f"FAIL: {result.stderr.strip()[:150]}")
        return

    current_raw = SNAPSHOTS_DIR / f"{test_name}.raw"
    baseline_raw = SNAPSHOTS_DIR / f"{test_name}.baseline.raw"

    if not current_raw.exists():
        print(f"No raw data for test '{test_name}'")
        return

    if not baseline_raw.exists():
        # Save current as baseline for next time
        import shutil
        shutil.copy2(current_raw, baseline_raw)
        print(f"PIXELDIFF: saved {test_name} baseline ({current_raw.stat().st_size} bytes)")
        print("  Run again after changes to see diff.")
        return

    # Compare byte-by-byte
    cur_data = current_raw.read_bytes()
    base_data = baseline_raw.read_bytes()

    if len(cur_data) != len(base_data):
        print(f"PIXELDIFF: size mismatch ({len(base_data)} → {len(cur_data)})")
        return

    pixel_count = len(cur_data) // 4
    diff_pixels = 0
    max_diff = 0
    diff_regions = []

    for i in range(pixel_count):
        off = i * 4
        br, bg, bb, ba = base_data[off:off+4]
        cr, cg, cb, ca = cur_data[off:off+4]
        d = abs(cr-br) + abs(cg-bg) + abs(cb-bb) + abs(ca-ba)
        if d > 0:
            diff_pixels += 1
            if d > max_diff:
                max_diff = d

    if diff_pixels == 0:
        print(f"PIXELDIFF: {test_name} — identical ({pixel_count} pixels)")
    else:
        pct = diff_pixels * 100.0 / pixel_count
        print(f"PIXELDIFF: {test_name} — {diff_pixels}/{pixel_count} pixels differ ({pct:.1f}%)")
        print(f"  max channel diff: {max_diff}")


