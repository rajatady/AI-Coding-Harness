def cmd_boundary(args):
    """
    Show API surface between layers. ~30 tokens output.
    This is the key tool for cross-layer work.

    Layers:
        wasm     — JS↔Rust boundary (#[wasm_bindgen] pub fns)
        engine   — Engine public API (pub fn in pub modules)
        renderer — Renderer public API
        crdt     — CRDT public API
        server   — Server endpoints (when it exists)

    Usage:
        ./ide boundary wasm      — all wasm_bindgen pub functions
        ./ide boundary engine    — engine's public API
        ./ide boundary all       — all boundaries (~100 tokens)
    """
    if not args:
        print("Usage: ./ide boundary <wasm|engine|renderer|crdt|server|all>")
        sys.exit(1)

    layer = args[0]

    if layer == "all":
        for l in ["wasm", "engine", "renderer", "crdt"]:
            _show_boundary(l)
            print()
    else:
        _show_boundary(layer)


def _show_boundary(layer: str):
    """Extract public API surface for a layer."""
    crate_map = {
        "wasm": IDE_ROOT / "crates" / "wasm" / "src",
        "engine": IDE_ROOT / "crates" / "engine" / "src",
        "renderer": IDE_ROOT / "crates" / "renderer" / "src",
        "crdt": IDE_ROOT / "crates" / "crdt" / "src",
    }

    src_dir = crate_map.get(layer)
    if not src_dir or not src_dir.exists():
        print(f"Layer '{layer}' not found")
        return

    print(f"── {layer} boundary ──")

    if layer == "wasm":
        # Special: only show #[wasm_bindgen] pub functions with full signatures
        for rs_file in sorted(src_dir.rglob("*.rs")):
            lines = rs_file.read_text().splitlines()
            in_wasm_impl = False
            collecting_sig = False
            sig_parts = []
            for i, line in enumerate(lines):
                stripped = line.strip()
                if '#[wasm_bindgen]' in stripped:
                    in_wasm_impl = True
                if collecting_sig:
                    sig_parts.append(stripped.split('{')[0].strip())
                    if '{' in stripped or stripped.endswith(')') or '->' in stripped:
                        full_sig = ' '.join(sig_parts)
                        if '{' in full_sig:
                            full_sig = full_sig.split('{')[0].strip()
                        print(f"  {full_sig}")
                        collecting_sig = False
                        sig_parts = []
                    continue
                if in_wasm_impl and stripped.startswith("pub fn "):
                    if '{' in stripped:
                        sig = stripped.split('{')[0].strip()
                        print(f"  {sig}")
                    else:
                        collecting_sig = True
                        sig_parts = [stripped]
                if in_wasm_impl and stripped == '}' and not line.startswith(' '):
                    in_wasm_impl = False
    else:
        # Show all pub fn signatures across the crate
        for rs_file in sorted(src_dir.rglob("*.rs")):
            rel = rs_file.relative_to(src_dir)
            fns = []
            lines = rs_file.read_text().splitlines()
            for line in lines:
                stripped = line.strip()
                if stripped.startswith("pub fn ") or stripped.startswith("pub async fn "):
                    sig = stripped.split('{')[0].strip()
                    fns.append(sig)
            if fns:
                print(f"  {rel}:")
                for f in fns:
                    print(f"    {f}")


