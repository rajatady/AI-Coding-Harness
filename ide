# ─── coherence ───────────────────────────────────────────────────────────
def cmd_coherence(args):
    """
    Detect files that may have been frankenstein'd by conflicting edits.
    Looks for symptoms of incoherent editing:
    - Duplicate pub/pub modifiers
    - Functions referenced but not defined (within same file)
    - Duplicate function names
    - Unbalanced braces
    - TODO/FIXME density (high = incomplete work)

    Usage:
        ./ide coherence <file>       — check one file
        ./ide coherence              — check all .rs files
    """
    if args:
        target = Path(args[0])
        if target.is_file():
            _check_coherence(target)
        else:
            print(f"Not found: {target}")
    else:
        issues_total = 0
        for f in sorted(IDE_ROOT.rglob("*.rs")):
            if "target" in f.parts:
                continue
            count = _check_coherence(f, quiet=True)
            issues_total += count
        if issues_total == 0:
            print("COHERENCE: OK")
        else:
            print(f"COHERENCE: {issues_total} issues")


def _check_coherence(path: Path, quiet: bool = False) -> int:
    """Check a single file for coherence issues. Returns issue count."""
    try:
        text = path.read_text()
        lines = text.splitlines()
    except Exception:
        return 0

    rel = path.relative_to(IDE_ROOT) if str(path).startswith(str(IDE_ROOT)) else path
    issues = []

    # 1. Duplicate visibility modifiers (pub pub)
    for i, line in enumerate(lines, 1):
        if "pub pub " in line:
            issues.append(f"  L{i}: duplicate 'pub pub'")

    # 2. Unbalanced braces
    open_b = text.count('{')
    close_b = text.count('}')
    if open_b != close_b:
        issues.append(f"  braces: {open_b} open, {close_b} close (diff={open_b - close_b})")

    # 3. Duplicate function definitions (scope-aware)
    # Track which impl block we're in to avoid false positives on new(), etc.
    fn_defs = []  # (scope, name, line)
    current_scope = "top"
    brace_depth = 0
    scope_stack = ["top"]
    for i, line in enumerate(lines, 1):
        stripped = line.strip()
        # Track impl blocks
        impl_match = re.match(r'(?:#\[.*\]\s*)?impl(?:<[^>]*>)?\s+(\S+)', stripped)
        if impl_match and '{' in line:
            current_scope = impl_match.group(1)

        # Match fn declarations
        fn_match = re.match(r'(?:pub(?:\([^)]*\))?\s+)?(?:async\s+)?(?:unsafe\s+)?(?:const\s+)?fn\s+(\w+)', stripped)
        if fn_match:
            fn_defs.append((current_scope, fn_match.group(1), i))

        # Very rough brace tracking to detect when we leave an impl
        brace_depth += line.count('{') - line.count('}')
        if brace_depth <= 0:
            current_scope = "top"
            brace_depth = 0

    # Only flag duplicates within the SAME scope
    scope_fns = {}
    for scope, name, lineno in fn_defs:
        key = (scope, name)
        if key in scope_fns:
            issues.append(f"  L{lineno}: duplicate fn '{name}' in {scope} (first at L{scope_fns[key]})")
        scope_fns[key] = lineno

    # 4. TODO/FIXME density
    todo_count = sum(1 for line in lines if 'TODO' in line or 'FIXME' in line or 'HACK' in line)
    if todo_count > 5:
        issues.append(f"  {todo_count} TODO/FIXME markers (high = incomplete)")

    # 5. Dead imports (use X but X never referenced in rest of file)
    # Lightweight check: just flag unusually high import count
    imports = [l.strip() for l in lines if l.strip().startswith("use ")]
    if len(imports) > 15:
        issues.append(f"  {len(imports)} imports (unusually high)")

    if issues:
        print(f"── {rel}: {len(issues)} issues ──")
        for issue in issues:
            print(issue)
    elif not quiet:
        print(f"── {rel}: OK ──")

    return len(issues)


