    cargo_toml = IDE_ROOT / "Cargo.toml"
    if not cargo_toml.exists():
        print("NO_CARGO")
        return

    # Find recently modified .rs files (last 5 minutes)
    import time
    cutoff = time.time() - 300  # 5 minutes
    changed = []
    for f in IDE_ROOT.rglob("*.rs"):
        if "target" in f.parts:
            continue
        if f.stat().st_mtime > cutoff:
            rel = f.relative_to(IDE_ROOT)
            changed.append(str(rel))

    if changed:
        print(f"CHANGED ({len(changed)}):")
        for c in changed[:10]:
