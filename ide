# ─── task (simplified — just active/next, no bloat) ─────────────────────
def cmd_task(args):
    if not args:
        print("Usage: ./ide task <add|start|done|block|list> ...")
        sys.exit(1)
    sub = args[0]

    if sub == "add":
        if len(args) < 4:
            print("Usage: ./ide task add <id> <title> <module> [acceptance...]")
            sys.exit(1)
        task = {
            "id": args[1], "title": args[2], "status": "pending",
            "blocked_by": [], "module": args[3],
            "subtasks": [],
            "acceptance": args[4:] if len(args) > 4 else [],
            "outcome": "",
        }
        save_json(TASKS_DIR / f"{args[1]}.json", task)
        print(f"Task: {args[1]}")

    elif sub == "start":
        path = TASKS_DIR / f"{args[1]}.json"
        t = load_json(path)
        t["status"] = "active"
        save_json(path, t)
        print(f"Started: {args[1]}")

    elif sub == "done":
        path = TASKS_DIR / f"{args[1]}.json"
        t = load_json(path)
        t["status"] = "done"
        t["outcome"] = args[2] if len(args) > 2 else ""
        save_json(path, t)
        print(f"Done: {args[1]}")
        for f in TASKS_DIR.glob("*.json"):
            other = load_json(f)
            if args[1] in other.get("blocked_by", []):
                other["blocked_by"].remove(args[1])
                save_json(f, other)
                print(f"  Unblocked: {other['id']}")

    elif sub == "block":
        path = TASKS_DIR / f"{args[1]}.json"
        t = load_json(path)
        if args[2] not in t["blocked_by"]:
            t["blocked_by"].append(args[2])
        save_json(path, t)
        print(f"Blocked: {args[1]} by {args[2]}")

    elif sub == "subtask":
        path = TASKS_DIR / f"{args[1]}.json"
        t = load_json(path)
        t["subtasks"].append({"title": args[2], "done": False})
        save_json(path, t)
        print(f"Subtask: {args[2]}")

    elif sub == "subtask-done":
        path = TASKS_DIR / f"{args[1]}.json"
        t = load_json(path)
        t["subtasks"][int(args[2])]["done"] = True
        save_json(path, t)

    elif sub == "list":
        for f in sorted(TASKS_DIR.glob("*.json")):
            t = load_json(f)
            if t["status"] != "done":
                bl = f" [blocked:{','.join(t['blocked_by'])}]" if t.get("blocked_by") else ""
                print(f"  {t['status']:7} [{t['id']}] {t['title']}{bl}")


