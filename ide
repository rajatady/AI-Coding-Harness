# ─── journal ─────────────────────────────────────────────────────────────
def cmd_journal(args):
    """
    Implementation journal — captures algorithmic state for context recovery.

    Usage:
        ./ide journal write <task_id> <content>  — Save/overwrite journal
        ./ide journal append <task_id> <content>  — Append to journal
        ./ide journal show <task_id>             — Read journal
        ./ide journal clear <task_id>            — Delete journal

    Journals are shown by `orient` when a task is active.
    After compaction, the journal tells you WHERE you were in the algorithm,
    not just WHAT task you were on.

    Content should capture:
    - Algorithm name and variant chosen
    - Current step (e.g., "implementing step 3 of 5: edge splitting")
    - Key invariants that must hold
    - What you tried that didn't work
    - What file(s) you're editing
    """
    if len(args) < 1:
        print("Usage: ./ide journal write|append|show|clear [task_id] [content]")
        return

    sub = args[0]
    # Default to "session" journal when no task_id given
    if len(args) < 2 or sub in ("write", "append") and len(args) >= 2 and not args[1].startswith("t"):
        task_id = "session"
        content_args = args[1:]
    else:
        task_id = args[1]
        content_args = args[2:]
    journal_path = JOURNALS_DIR / f"{task_id}.md"

    if sub == "write":
        content = " ".join(content_args) if content_args else ""
        journal_path.write_text(content + "\n")
        print(f"JOURNAL: {task_id} written ({len(content)} chars)")

    elif sub == "append":
        content = " ".join(content_args) if content_args else ""
        with open(journal_path, "a") as f:
            f.write(content + "\n")
        print(f"JOURNAL: {task_id} appended")

    elif sub == "show":
        if journal_path.exists():
            print(journal_path.read_text().strip())
        else:
            print(f"JOURNAL: {task_id} (empty)")

    elif sub == "clear":
        if journal_path.exists():
            journal_path.unlink()
            print(f"JOURNAL: {task_id} cleared")
        else:
            print(f"JOURNAL: {task_id} (already empty)")

    else:
        print(f"Unknown journal sub: {sub}")


