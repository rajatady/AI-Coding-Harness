    markers = {"TODO": 0, "FIXME": 0, "HACK": 0, "unwrap()": 0, "unsafe": 0, "clone()": 0}
    files_with_debt = {}

    for ext, dirs in [("*.rs", [IDE_ROOT / "crates"]), ("*.ts", [IDE_ROOT / "app" / "src"])]:
        for d in dirs:
            for f in d.rglob(ext):
                text = f.read_text()
                for marker in markers:
                    count = text.count(marker)
                    if count > 0:
                        markers[marker] += count
                        rel = str(f.relative_to(IDE_ROOT))
                        if rel not in files_with_debt:
                            files_with_debt[rel] = {}
                        files_with_debt[rel][marker] = count

    print("DEBT SCAN:")
    for marker, count in sorted(markers.items(), key=lambda x: -x[1]):
        if count > 0:
            print(f"  {marker:12s} {count:4d}")

    if args and args[0] == "-v":
        print("\nPER-FILE:")
        for f, counts in sorted(files_with_debt.items(), key=lambda x: -sum(x[1].values())):
            total = sum(counts.values())
            detail = ", ".join(f"{k}:{v}" for k, v in counts.items() if v > 0)
            print(f"  {total:3d}  {f}  ({detail})")


def cmd_wired(args):
    """
    Show which WASM pub fn methods are called from TypeScript and which aren't.
    Helps find unwired APIs. ~20 tokens.
    """
    lib_rs = IDE_ROOT / "crates" / "wasm" / "src" / "lib.rs"
    main_ts = IDE_ROOT / "app" / "src" / "main.ts"
    if not lib_rs.exists() or not main_ts.exists():
        print("Missing lib.rs or main.ts")
        return
    # Extract pub fn names from lib.rs
    wasm_fns = set()
    for line in lib_rs.read_text().splitlines():
        m = re.search(r"pub fn (\w+)", line.strip())
        if m:
            wasm_fns.add(m.group(1))
    # Skip internal/lifecycle methods
    skip = {"new", "render", "render_canvas2d", "tick"}
    wasm_fns -= skip
    # Check which are referenced in main.ts
    ts_text = main_ts.read_text()
    wired = set()
    unwired = set()
    for fn in sorted(wasm_fns):
        if fn in ts_text:
            wired.add(fn)
        else:
            unwired.add(fn)
    print(f"WIRED ({len(wired)}):")
    for fn in sorted(wired):
        print(f"  + {fn}")
    if unwired:
        print(f"\nUNWIRED ({len(unwired)}):")
        for fn in sorted(unwired):
            print(f"  - {fn}")


