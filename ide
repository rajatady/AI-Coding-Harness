def cmd_smoke(args):
    """
    Full pipeline smoke test: tests + WASM build + perf benchmark.
    One command to verify nothing is broken.
    Usage: ./ide smoke
    """
    print("── Smoke Test ──")
    fail = False

    # 1. Rust tests
    print("  [1/3] Tests...", end=" ", flush=True)
    r = subprocess.run(
        ["cargo", "test", "--workspace", "-q"],
        capture_output=True, text=True, cwd=str(IDE_ROOT), timeout=120,
    )
    if r.returncode == 0:
        # Count tests
        for line in r.stderr.splitlines():
            if "test result" in line:
                print(f"OK ({line.strip()})")
                break
        else:
            print("OK")
    else:
        print(f"FAIL\n{r.stderr[:300]}")
        fail = True

    # 2. WASM build
    print("  [2/3] WASM...", end=" ", flush=True)
    r = subprocess.run(
        ["cargo", "build", "--target", "wasm32-unknown-unknown", "-p", "figma-wasm"],
        capture_output=True, text=True, cwd=str(IDE_ROOT), timeout=120,
    )
    if r.returncode == 0:
        # wasm-bindgen
        wasm_file = IDE_ROOT / "target" / "wasm32-unknown-unknown" / "debug" / "figma_wasm.wasm"
        r2 = subprocess.run(
            ["wasm-bindgen", str(wasm_file), "--out-dir", str(IDE_ROOT / "app" / "src" / "wasm"), "--target", "web"],
            capture_output=True, text=True, timeout=30,
        )
        if r2.returncode == 0:
            print("OK")
        else:
            print(f"FAIL (bindgen)\n{r2.stderr[:200]}")
            fail = True
    else:
        print(f"FAIL\n{r.stderr[:300]}")
        fail = True

    # 3. Perf benchmark
    print("  [3/3] Perf...", end=" ", flush=True)
    r = subprocess.run(
        ["cargo", "test", "--package", "figma-renderer", "--test", "apple_website",
         "perf_80k", "--", "--exact", "--nocapture"],
        capture_output=True, text=True, cwd=str(IDE_ROOT), timeout=120,
    )
    for line in r.stdout.splitlines() + r.stderr.splitlines():
        if "ms/frame" in line.lower() or "TOTAL" in line:
            ms_match = None
            for part in line.split():
                try:
                    ms_match = float(part.replace("ms/frame", ""))
                except ValueError:
                    pass
            if ms_match and ms_match < 16.6:
                print(f"OK ({line.strip()})")
            elif ms_match:
                print(f"SLOW ({line.strip()})")
            else:
                print(line.strip())
            break
    else:
        if r.returncode == 0:
            print("OK (no timing found)")
        else:
            print("FAIL")
            fail = True

    print()
    if fail:
        print("SMOKE: FAIL")
        sys.exit(1)
    else:
        print("SMOKE: OK — all checks passed")


def cmd_keys(args):
    """
    List all keyboard shortcuts registered in main.ts.
    Usage: ./ide keys
    """
    main_ts = IDE_ROOT / "app" / "src" / "main.ts"
    if not main_ts.exists():
        print("main.ts not found")
        return

    shortcuts = []
    lines = main_ts.read_text().splitlines()
    import re
    for i, line in enumerate(lines, 1):
        stripped = line.strip()
        # Match patterns like: e.key === 'x', e.code === 'Space'
        # Also Cmd/Ctrl combos
        if "e.key ===" in stripped or "e.code ===" in stripped:
            # Extract the key
            keys_found = re.findall(r"e\.(?:key|code)\s*===\s*'([^']+)'", stripped)
            has_meta = "metaKey" in stripped or "ctrlKey" in stripped
            has_shift = "shiftKey" in stripped

            # Find what it does — look at next few lines for the action
            action = ""
            for j in range(i, min(i + 5, len(lines))):
                aline = lines[j].strip()
                if "app." in aline:
                    action = re.search(r"app\.(\w+)", aline)
                    action = action.group(1) if action else ""
                    break
                if "=" in aline and "app." not in aline:
                    action = aline.split("//")[0].strip().rstrip(";")
                    break

            for key in keys_found:
                mod = ""
                if has_meta:
                    mod = "Cmd+"
                if has_shift:
                    mod += "Shift+"
                shortcuts.append((f"{mod}{key}", action, i))

    print(f"── {len(shortcuts)} Keyboard Shortcuts ──")
    for combo, action, line in shortcuts:
        print(f"  {combo:20s} → {action:30s} (line {line})")

def cmd_todo(args):
    """
    Scan codebase for TODO/FIXME/HACK comments.
    Usage: ./ide todo          — all TODOs
           ./ide todo <filter> — grep within TODOs
    """
    filter_term = args[0].lower() if args else None
    todos = []
    for ext in ("*.rs", "*.ts"):
        for path in IDE_ROOT.rglob(ext):
            if "target" in str(path) or "node_modules" in str(path) or "/wasm/" in str(path) and path.name.endswith(".d.ts"):
                continue
            try:
                for i, line in enumerate(path.read_text().splitlines(), 1):
                    stripped = line.strip()
                    for marker in ("TODO", "FIXME", "HACK", "XXX"):
                        if marker in stripped:
                            rel = path.relative_to(IDE_ROOT)
                            text = stripped.lstrip("/ ").lstrip("*").strip()
                            if filter_term and filter_term not in text.lower():
                                continue
                            todos.append((str(rel), i, marker, text))
                            break
            except Exception:
                pass

    if not todos:
        print("No TODOs found." if not filter_term else f"No TODOs matching '{filter_term}'.")
        return

    print(f"── {len(todos)} TODOs ──")
    for rel, line, marker, text in sorted(todos):
        print(f"  {rel}:{line}  {text[:90]}")

def cmd_deps(args):
    """
    Show crate dependency graph and public API surface.
    Usage: ./ide deps          — full graph
           ./ide deps <crate>  — what depends on <crate> + its exports
    """
    crates_dir = IDE_ROOT / "crates"
    # Build dependency map
    dep_map = {}  # crate_name -> [dependencies]
    reverse_map = {}  # crate_name -> [dependents]
    crate_dirs = {}
    for toml_path in sorted(crates_dir.glob("*/Cargo.toml")):
        crate_name = None
        deps = []
        in_deps = False
        for line in toml_path.read_text().splitlines():
            if line.strip().startswith("name ="):
                crate_name = line.split('"')[1]
            if line.strip() == "[dependencies]":
                in_deps = True
                continue
            if line.strip().startswith("[") and in_deps:
                in_deps = False
            if in_deps and "figma-" in line:
                dep_name = line.split("=")[0].strip()
                deps.append(dep_name)
        if crate_name:
            dep_map[crate_name] = deps
            crate_dirs[crate_name] = toml_path.parent
            reverse_map.setdefault(crate_name, [])
            for d in deps:
                reverse_map.setdefault(d, []).append(crate_name)

    # Also count pub items
    def count_pub(crate_dir):
        pub_fns = 0
        pub_structs = 0
        pub_enums = 0
        for rs in crate_dir.rglob("*.rs"):
            for line in rs.read_text().splitlines():
                stripped = line.strip()
                if stripped.startswith("pub fn ") or stripped.startswith("pub async fn "):
                    pub_fns += 1
                elif stripped.startswith("pub struct "):
                    pub_structs += 1
                elif stripped.startswith("pub enum "):
                    pub_enums += 1
        return pub_fns, pub_structs, pub_enums

    filter_crate = args[0] if args else None

    if filter_crate:
        # Find matching crate
        match = None
        for name in dep_map:
            if filter_crate in name:
                match = name
                break
        if not match:
            print(f"No crate matching '{filter_crate}'")
            sys.exit(1)
        fns, structs, enums = count_pub(crate_dirs[match])
        print(f"── {match} ──")
        print(f"  Depends on: {', '.join(dep_map[match]) or '(none)'}")
        print(f"  Used by:    {', '.join(reverse_map.get(match, [])) or '(none)'}")
        print(f"  Public API: {fns} fns, {structs} structs, {enums} enums")
        # Show pub fn signatures
        print()
        for rs in sorted(crate_dirs[match].rglob("*.rs")):
            rel = rs.relative_to(crate_dirs[match])
            found = []
            for i, line in enumerate(rs.read_text().splitlines(), 1):
                stripped = line.strip()
                if stripped.startswith("pub fn ") or stripped.startswith("pub async fn "):
                    sig = stripped.split("{")[0].strip()
                    if sig.endswith(","):
                        sig = sig[:-1] + "..."
                    found.append(f"    {i}: {sig}")
            if found:
                print(f"  {rel}:")
                for f in found:
                    print(f)
    else:
        # Full graph
        print("── Crate Dependency Graph ──")
        print()
        # Topological display
        printed = set()
        def print_crate(name, depth=0):
            if name in printed:
                return
            # Print deps first
            for d in dep_map.get(name, []):
                print_crate(d, depth)
            printed.add(name)
            fns, structs, enums = count_pub(crate_dirs[name])
            indent = "  " * depth
            deps_str = f" → {', '.join(dep_map[name])}" if dep_map[name] else ""
            used_str = f" ← {', '.join(reverse_map.get(name, []))}" if reverse_map.get(name, []) else ""
            print(f"  {name:20s} {fns:3d} fns  {structs:2d} structs  {enums:2d} enums{deps_str}{used_str}")

        for name in sorted(dep_map.keys()):
            print_crate(name)

        print()
        print("  Arrow: → depends on, ← used by")

def cmd_test_import(args):
    """
    Headless .fig import validation — no browser needed.
    Checks all 5 fig JSON files parse and have expected node counts.
    Usage: ./ide test-import
    """
    imports_dir = IDE_ROOT / "imports"
    expected = {
        "Coffee Shop Mobile App Design (Community)-extracted": {"json": "canvas.json", "min_nodes": 1400},
        "apple-extracted": {"json": "canvas.json", "min_nodes": 19000},
        "GEE! ME 100 Characters Pack (Community)-extracted": {"json": "canvas.json", "min_nodes": 11000},
        "iOS 16 UI Kit for Figma (Community)-extracted": {"json": "canvas.json", "min_nodes": 7900},
        "Relume Figma Kit (v3.7) (Community)-extracted": {"json": "canvas.json", "min_nodes": 100000},
    }

    passed = 0
    failed = 0
    total_nodes = 0

    for dir_name, spec in expected.items():
        json_path = imports_dir / dir_name / spec["json"]
        if not json_path.exists():
            print(f"  FAIL  {dir_name}: {spec['json']} not found")
            failed += 1
            continue

        try:
            data = json.loads(json_path.read_text())
        except Exception as e:
            print(f"  FAIL  {dir_name}: JSON parse error: {e}")
            failed += 1
            continue

        # Count nodes recursively
        def count_nodes(node):
            n = 1
            for child in node.get("children", []):
                n += count_nodes(child)
            return n

        nodes = 0
        doc = data.get("document", {})
        for page in doc.get("children", []):
            nodes += count_nodes(page)

        total_nodes += nodes
        if nodes >= spec["min_nodes"]:
            print(f"  OK    {dir_name}: {nodes:,} nodes")
            passed += 1
        else:
            print(f"  FAIL  {dir_name}: {nodes:,} nodes (expected >= {spec['min_nodes']:,})")
            failed += 1

    # Also check images exist
    image_dirs = 0
    image_count = 0
    for dir_name in expected:
        img_dir = imports_dir / dir_name / "images"
        if img_dir.is_dir():
            image_dirs += 1
            image_count += len(list(img_dir.iterdir()))

    print()
    print(f"  Files:  {passed}/{len(expected)} pass")
    print(f"  Nodes:  {total_nodes:,} total")
    print(f"  Images: {image_count:,} across {image_dirs} dirs")

    if failed > 0:
        print(f"\nIMPORT: FAIL ({failed} failures)")
        sys.exit(1)
    else:
        print(f"\nIMPORT: OK")


def cmd_compare(args):
    """
    Pixel comparison: our render vs reference (Figma screenshot).
    Usage: ./ide compare <reference.png> <ours.png>
           ./ide compare <reference.png> <ours.png> --html  (open visual diff)

    Outputs: SSIM score, pixel diff count, and difference image.
    SSIM > 0.95 = visually close. SSIM < 0.80 = major gaps.
    """
    if len(args) < 2:
        print("Usage: ./ide compare <reference.png> <ours.png> [--html]")
        sys.exit(1)

    ref_path = Path(args[0])
    our_path = Path(args[1])
    html_mode = "--html" in args

    if not ref_path.exists():
        print(f"Reference not found: {ref_path}")
        sys.exit(1)
    if not our_path.exists():
        print(f"Our render not found: {our_path}")
        sys.exit(1)

    # Use Python + PIL for comparison (available via Pillow)
    try:
        from PIL import Image as PILImage
        import math
    except ImportError:
        print("Pillow not installed. Run: pip install Pillow")
        sys.exit(1)

    ref_img = PILImage.open(ref_path).convert("RGBA")
    our_img = PILImage.open(our_path).convert("RGBA")

    # Resize our image to match reference if needed
    if ref_img.size != our_img.size:
        print(f"  Size mismatch: ref={ref_img.size} ours={our_img.size}")
        our_img = our_img.resize(ref_img.size, PILImage.Resampling.LANCZOS)
        print(f"  Resized ours to {ref_img.size}")

    w, h = ref_img.size
    ref_px = ref_img.load()
    our_px = our_img.load()

    # Compute per-pixel difference
    diff_img = PILImage.new("RGBA", (w, h))
    diff_px = diff_img.load()
    total_diff = 0
    pixel_diffs = 0
    max_diff = 0

    for y in range(h):
        for x in range(w):
            r1, g1, b1, a1 = ref_px[x, y]
            r2, g2, b2, a2 = our_px[x, y]
            dr = abs(r1 - r2)
            dg = abs(g1 - g2)
            db = abs(b1 - b2)
            da = abs(a1 - a2)
            pixel_err = dr + dg + db + da
            total_diff += pixel_err
            if pixel_err > 10:  # threshold: ignore sub-pixel rounding
                pixel_diffs += 1
                # Highlight differences in red
                intensity = min(255, pixel_err * 2)
                diff_px[x, y] = (intensity, 0, 0, 255)
            else:
                # Show original dimmed
                diff_px[x, y] = (r2 // 3, g2 // 3, b2 // 3, 128)
            max_diff = max(max_diff, pixel_err)

    total_pixels = w * h
    diff_pct = (pixel_diffs / total_pixels) * 100
    avg_err = total_diff / (total_pixels * 4)  # per channel average

    # Simple SSIM approximation (luminance-based)
    # Real SSIM needs windowed stats, this is a fast approximation
    ref_lum = []
    our_lum = []
    for y in range(h):
        for x in range(w):
            r1, g1, b1, a1 = ref_px[x, y]
            r2, g2, b2, a2 = our_px[x, y]
            ref_lum.append(0.299 * r1 + 0.587 * g1 + 0.114 * b1)
            our_lum.append(0.299 * r2 + 0.587 * g2 + 0.114 * b2)

    n = len(ref_lum)
    mean_r = sum(ref_lum) / n
    mean_o = sum(our_lum) / n
    var_r = sum((x - mean_r) ** 2 for x in ref_lum) / n
    var_o = sum((x - mean_o) ** 2 for x in our_lum) / n
    cov = sum((ref_lum[i] - mean_r) * (our_lum[i] - mean_o) for i in range(n)) / n

    C1 = (0.01 * 255) ** 2
    C2 = (0.03 * 255) ** 2
    ssim = ((2 * mean_r * mean_o + C1) * (2 * cov + C2)) / \
           ((mean_r ** 2 + mean_o ** 2 + C1) * (var_r + var_o + C2))

    # Save diff image
    diff_path = our_path.parent / f"{our_path.stem}_diff.png"
    diff_img.save(diff_path)

    print(f"  Reference: {ref_path.name} ({w}x{h})")
    print(f"  Ours:      {our_path.name}")
    print(f"  SSIM:      {ssim:.4f}")
    print(f"  Diff:      {pixel_diffs:,}/{total_pixels:,} pixels ({diff_pct:.1f}%)")
    print(f"  Avg err:   {avg_err:.2f}/255 per channel")
    print(f"  Max err:   {max_diff}")
    print(f"  Diff img:  {diff_path}")

    if ssim >= 0.95:
        print(f"\nCOMPARE: CLOSE (SSIM {ssim:.4f})")
    elif ssim >= 0.80:
        print(f"\nCOMPARE: GAPS (SSIM {ssim:.4f})")
    else:
        print(f"\nCOMPARE: MAJOR DIFFERENCES (SSIM {ssim:.4f})")

    if html_mode:
        html_path = our_path.parent / f"{our_path.stem}_compare.html"
        import base64
        def img_to_data_uri(img):
            import io
            buf = io.BytesIO()
            img.save(buf, format="PNG")
            return base64.b64encode(buf.getvalue()).decode()

        html = f"""<!DOCTYPE html><html><head><style>
        body {{ font-family: monospace; background: #111; color: #fff; display: flex; flex-wrap: wrap; gap: 10px; padding: 10px; }}
        .panel {{ text-align: center; }}
        img {{ max-width: 600px; border: 1px solid #333; }}
        h3 {{ margin: 5px 0; }}
        </style></head><body>
        <div class="panel"><h3>Reference (Figma)</h3><img src="data:image/png;base64,{img_to_data_uri(ref_img)}"></div>
        <div class="panel"><h3>Ours (SSIM: {ssim:.4f})</h3><img src="data:image/png;base64,{img_to_data_uri(our_img)}"></div>
        <div class="panel"><h3>Diff ({diff_pct:.1f}% pixels)</h3><img src="data:image/png;base64,{img_to_data_uri(diff_img)}"></div>
        </body></html>"""
        html_path.write_text(html)
        print(f"  HTML:      {html_path}")
        subprocess.run(["open", str(html_path)])


