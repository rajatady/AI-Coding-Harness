# ─── verify (redesigned — binary signals) ───────────────────────────────
def cmd_verify(args):
    """
    Full verification sweep. Returns structured, minimal output.
    Cost: ~100-200 tokens total even for a large project.
    """
    issues = []

    # Compile check
    cargo_toml = IDE_ROOT / "Cargo.toml"
    if cargo_toml.exists():
        result = subprocess.run(
            ["cargo", "check", "--message-format=short"],
            capture_output=True, text=True, cwd=IDE_ROOT, timeout=120
        )
        if result.returncode != 0:
            issues.append("COMPILE: FAIL")
        else:
            # Also check wasm target
            result = subprocess.run(
                ["cargo", "check", "--target", "wasm32-unknown-unknown", "--message-format=short"],
                capture_output=True, text=True, cwd=IDE_ROOT, timeout=120
            )
            if result.returncode != 0:
                issues.append("WASM: FAIL")

    # Contract compilation
    for f in CONTRACTS_DIR.glob("*.rs"):
        result = subprocess.run(
            ["rustc", "--edition=2021", "--crate-type=lib", str(f), "-o", "/dev/null"],
            capture_output=True, text=True, timeout=30
        )
        if result.returncode != 0:
            issues.append(f"CONTRACT {f.stem}: FAIL")

    # Task integrity
    task_ids = {f.stem for f in TASKS_DIR.glob("*.json")}
    for f in TASKS_DIR.glob("*.json"):
        t = load_json(f)
        for dep in t.get("blocked_by", []):
            if dep not in task_ids:
                issues.append(f"TASK {t['id']}: blocked by missing {dep}")

    # Module health
    for f in MODULES_DIR.glob("*.json"):
        m = load_json(f)
        if m["status"] == "complete" and m.get("known_issues"):
            issues.append(f"MODULE {m['name']}: complete but has issues")

    if not issues:
        print("VERIFY: ALL OK")
    else:
        print(f"VERIFY: {len(issues)} ISSUES")
        for issue in issues:
            print(f"  {issue}")


# ─── survey ──────────────────────────────────────────────────────────────
def cmd_survey(args):
    """
    Structural skeleton of a Rust file. ~20-40 tokens output.
    Shows WHAT EXISTS without reading the full file.

    This prevents the #1 pain: editing a file you don't understand.
    Read the survey BEFORE any edit. Know the shape.

    Usage:
        ./ide survey <file>              — skeleton of one file
        ./ide survey <crate-dir>/src/    — skeleton of all files in a module
    """
    if not args:
        print("Usage: ./ide survey <file-or-dir>")
        sys.exit(1)

    target = Path(args[0])
    if target.is_dir():
        for f in sorted(target.rglob("*.rs")):
            _survey_file(f)
            print()
    elif target.is_file():
        _survey_file(target)
    else:
        print(f"Not found: {target}")
        sys.exit(1)


def _survey_file(path: Path):
    """Extract structural skeleton from a Rust file. Minimal output."""
    try:
        lines = path.read_text().splitlines()
    except Exception as e:
        print(f"ERR: {e}")
        return

    rel = path.relative_to(IDE_ROOT) if str(path).startswith(str(IDE_ROOT)) else path
    print(f"── {rel} ({len(lines)} lines) ──")

    for i, line in enumerate(lines, 1):
        stripped = line.strip()
        # Skip empty lines, comments, use statements, attributes
        if not stripped or stripped.startswith("//") or stripped.startswith("use ") or stripped.startswith("#["):
            continue

        # Module declarations
        if stripped.startswith("pub mod ") or stripped.startswith("mod "):
            print(f"  {i}: {stripped}")
            continue

        # Struct/enum/trait declarations
        for kw in ["pub struct ", "struct ", "pub enum ", "enum ", "pub trait ", "trait "]:
            if stripped.startswith(kw):
                # Include up to opening brace or semicolon
                print(f"  {i}: {stripped.split('{')[0].strip()}")
                break

        # Function/method signatures
        for kw in ["pub fn ", "fn ", "pub async fn ", "async fn ", "pub const fn ", "const fn ", "pub unsafe fn "]:
            if stripped.startswith(kw) or (stripped.startswith("pub(crate) fn ") or stripped.startswith("pub(super) fn ")):
                # Extract up to opening brace
                sig = stripped.split('{')[0].strip()
                if sig.endswith(')') or sig.endswith('-> '):
                    # Multi-line signature, just show what we have
                    pass
                print(f"  {i}: {sig}")
                break

        # Impl blocks
        if stripped.startswith("impl ") or stripped.startswith("impl<"):
            block = stripped.split('{')[0].strip()
            print(f"  {i}: {block}")


