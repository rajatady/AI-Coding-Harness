def cmd_hot(args):
    """
    Find hotspot functions — longest pub fn blocks in lib.rs.
    Helps decide when to refactor. ~15 tokens.
    """
    lib_rs = IDE_ROOT / "crates" / "wasm" / "src" / "lib.rs"
    if not lib_rs.exists():
        print("lib.rs not found")
        return
    lines = lib_rs.read_text().splitlines()
    fns = []
    cur_fn = None
    cur_start = 0
    depth = 0
    for i, line in enumerate(lines, 1):
        stripped = line.strip()
        if stripped.startswith("pub fn ") or stripped.startswith("fn "):
            m = re.search(r"(?:pub )?fn (\w+)", stripped)
            if m:
                cur_fn = m.group(1)
                cur_start = i
                depth = 0
        depth += stripped.count('{') - stripped.count('}')
        if cur_fn and depth <= 0 and '{' in ''.join(lines[cur_start-1:i]):
            length = i - cur_start + 1
            fns.append((length, cur_fn, cur_start))
            cur_fn = None
    fns.sort(reverse=True)
    print("HOTSPOTS (longest functions):")
    for length, name, start in fns[:10]:
        print(f"  {length:4d} lines  {name} (line {start})")


