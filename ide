def cmd_api(args):
    """
    Show complete public API surface of a crate: structs, enums, traits,
    functions, AND methods inside impl blocks.

    This is the tool that prevents signature-guessing pain.
    Before calling any function from another crate, run this first.

    Usage:
        ./ide api <crate>           — full API surface
        ./ide api <crate> <type>    — filter to specific type's methods
        ./ide api <crate> fns       — only standalone pub fns
        ./ide api <crate> types     — only pub struct/enum/trait
    """
    if not args:
        print("Usage: ./ide api <crate> [type|fns|types]")
        sys.exit(1)

    crate_name = args[0]
    filter_arg = args[1] if len(args) > 1 else None
    src_dir = IDE_ROOT / "crates" / crate_name / "src"

    if not src_dir.exists():
        print(f"Crate '{crate_name}' not found")
        available = [d.name for d in (IDE_ROOT / "crates").iterdir() if d.is_dir()]
        print(f"  Available: {', '.join(available)}")
        sys.exit(1)

    print(f"── {crate_name} API ──")

    for rs_file in sorted(src_dir.rglob("*.rs")):
        rel = rs_file.relative_to(src_dir)
        items = _extract_api(rs_file, filter_arg)
        if items:
            print(f"  {rel}:")
            for item in items:
                print(f"    {item}")


def _extract_api(path: Path, filter_arg: str | None) -> list[str]:
    """Extract public API items from a Rust source file."""
    try:
        lines = path.read_text().splitlines()
    except Exception:
        return []

    items = []
    current_impl = None  # Track what impl block we're in
    brace_depth = 0
    impl_brace_depth = 0
    in_impl = False

    for line in lines:
        stripped = line.strip()

        # Track impl blocks
        impl_match = re.match(
            r'impl(?:<[^>]*>)?\s+(?:(\w+(?:<[^>]*>)?)\s+for\s+)?(\w+(?:<[^>]*>)?)',
            stripped
        )
        if impl_match and '{' in stripped:
            current_impl = impl_match.group(2)
            if impl_match.group(1):
                current_impl = f"{impl_match.group(2)} (impl {impl_match.group(1)})"
            in_impl = True
            impl_brace_depth = brace_depth

        # Track braces
        brace_depth += stripped.count('{') - stripped.count('}')
        if in_impl and brace_depth <= impl_brace_depth:
            in_impl = False
            current_impl = None

        # Skip non-pub items
        if not stripped.startswith("pub ") and not stripped.startswith("pub(crate)"):
            continue

        # Filter modes
        if filter_arg == "fns" and not any(kw in stripped for kw in ["pub fn ", "pub async fn "]):
            continue
        if filter_arg == "types" and not any(kw in stripped for kw in ["pub struct ", "pub enum ", "pub trait ", "pub type "]):
            continue

        # Extract signature
        sig = stripped.split('{')[0].strip()
        if sig.endswith(','):
            sig = sig[:-1]

        # Type definitions
        for kw in ["pub struct ", "pub enum ", "pub trait ", "pub type "]:
            if stripped.startswith(kw):
                items.append(sig)
                break
        else:
            # Function/method signatures
            for kw in ["pub fn ", "pub async fn ", "pub const fn ", "pub unsafe fn "]:
                if kw in stripped:
                    if current_impl and filter_arg and filter_arg not in ("fns", "types"):
                        # Filtering by type name — only show if impl matches
                        if filter_arg.lower() not in current_impl.lower():
                            break
                    prefix = f"  [{current_impl}] " if current_impl else ""
                    items.append(f"{prefix}{sig}")
                    break

    return items


# ─── impact ──────────────────────────────────────────────────────────────
def cmd_impact(args):
    """
    Show which test files import/use a given module.
    Answers: "I changed X, what tests might break?"

    Usage:
        ./ide impact <file-or-module>    — find tests that import this
        ./ide impact rasterize           — which tests use rasterize?
        ./ide impact scene               — which tests use scene?
    """
    if not args:
        print("Usage: ./ide impact <file-or-module-name>")
        sys.exit(1)

    target = args[0]
    # Normalize: strip path prefix, extension
    target_name = Path(target).stem  # "rasterize.rs" → "rasterize"

    # Search test files for imports of this module
    test_dirs = [
        IDE_ROOT / "crates" / "renderer" / "tests",
        IDE_ROOT / "crates" / "engine" / "tests",
        IDE_ROOT / "crates" / "crdt" / "tests",
    ]

    # Also search src/bin for binaries that use this
    bin_dirs = [
        IDE_ROOT / "crates" / "renderer" / "src" / "bin",
    ]

    hits = []
    for d in test_dirs + bin_dirs:
        if not d.exists():
            continue
        for f in sorted(d.glob("*.rs")):
            text = f.read_text()
            # Check for direct module references or use statements
            if target_name in text:
                rel = f.relative_to(IDE_ROOT)
                # Count how many times it's referenced
                count = text.count(target_name)
                hits.append((str(rel), count))

    # Also check which internal modules import this
